<Window
    x:Class="Linksoft.VideoSurveillance.Wpf.Windows.FullScreenCameraWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lve="clr-namespace:Linksoft.VideoPlayer.Wpf;assembly=Linksoft.VideoPlayer.Wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:coreControls="clr-namespace:Linksoft.VideoSurveillance.Wpf.Core.UserControls;assembly=Linksoft.VideoSurveillance.Wpf.Core"
    xmlns:windows="clr-namespace:Linksoft.VideoSurveillance.Wpf.Windows"
    Title="{Binding Path=CameraName}"
    d:DataContext="{d:DesignInstance Type=windows:FullScreenCameraWindowViewModel,
                                     IsDesignTimeCreatable=False}"
    AllowsTransparency="False"
    Background="Black"
    ResizeMode="NoResize"
    ShowInTaskbar="True"
    Topmost="True"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>
        <ResourceDictionary Source="/Linksoft.VideoSurveillance.Wpf.Core;component/Themes/FullScreenStyles.xaml" />
    </Window.Resources>

    <!--  ReSharper disable Xaml.BindingWithContextNotResolved  -->
    <Grid x:Name="RootGrid">
        <!--  Video Player with visual overlay inside (required due to DirectX airspace)  -->
        <lve:VideoHost
            x:Name="VideoPlayer"
            Player="{Binding Path=Player}">

            <!--  Visual overlay content - renders on top of video  -->
            <Grid Background="Transparent">
                <!--  Camera Info Overlay (Top-Left)  -->
                <Border
                    x:Name="OverlayBorder"
                    Margin="20"
                    Padding="12,8"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#B3000000"
                    CornerRadius="4"
                    Opacity="{Binding Path=HostDataContext.IsOverlayVisible, Converter={StaticResource BoolToOpacityConverter}}">
                    <StackPanel Orientation="Vertical">
                        <!--  Camera Title  -->
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding Path=HostDataContext.CameraName}" />
                        <!--  Camera Description  -->
                        <TextBlock
                            FontSize="12"
                            Foreground="#AAAAAA"
                            Text="{Binding Path=HostDataContext.CameraDescription}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=HostDataContext.CameraDescription}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!--  Connection Status  -->
                        <StackPanel
                            Margin="0,4,0,0"
                            Orientation="Horizontal">
                            <Ellipse
                                Width="10"
                                Height="10"
                                Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=HostDataContext.ConnectionState}" Value="connected">
                                                <Setter Property="Fill" Value="LimeGreen" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Path=HostDataContext.ConnectionState}" Value="connecting">
                                                <Setter Property="Fill" Value="Orange" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Path=HostDataContext.ConnectionState}" Value="error">
                                                <Setter Property="Fill" Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock
                                FontSize="11"
                                Foreground="#AAAAAA"
                                Text="{Binding Path=HostDataContext.ConnectionState}" />
                        </StackPanel>
                        <!--  Recording indicator  -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=HostDataContext.IsRecording}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Ellipse
                                Width="8"
                                Height="8"
                                Margin="0,2,6,0"
                                Fill="Red" />
                            <TextBlock
                                FontSize="11"
                                Foreground="Red"
                                Text="REC" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Motion Bounding Box Overlay  -->
                <coreControls:MotionBoundingBoxOverlay
                    x:Name="MotionOverlay"
                    AnalysisHeight="{Binding Path=HostDataContext.AnalysisHeight}"
                    AnalysisWidth="{Binding Path=HostDataContext.AnalysisWidth}"
                    IsHitTestVisible="False" />

                <!--  Close Button (Top-Right)  -->
                <Button
                    Width="40"
                    Height="40"
                    Margin="20"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Command="{Binding Path=HostDataContext.CloseCommand}"
                    Opacity="{Binding Path=HostDataContext.IsOverlayVisible, Converter={StaticResource BoolToOpacityConverter}}"
                    Style="{StaticResource FullScreenCloseButtonStyle}"
                    ToolTip="Close">
                    <Path
                        Width="14"
                        Height="14"
                        Data="M0,0 L14,14 M14,0 L0,14"
                        Stroke="White"
                        StrokeThickness="2" />
                </Button>

                <!--  ESC hint at bottom  -->
                <TextBlock
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    FontSize="12"
                    Foreground="#66FFFFFF"
                    Opacity="{Binding Path=HostDataContext.IsOverlayVisible, Converter={StaticResource BoolToOpacityConverter}}"
                    Text="Press ESC to exit" />
            </Grid>
        </lve:VideoHost>
    </Grid>
    <!--  ReSharper restore Xaml.BindingWithContextNotResolved  -->
</Window>