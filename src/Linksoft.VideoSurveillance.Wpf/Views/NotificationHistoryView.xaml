<UserControl
    x:Class="Linksoft.VideoSurveillance.Wpf.Views.NotificationHistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:Linksoft.VideoSurveillance.Wpf.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:NotificationHistoryViewModel}"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Title bar with Clear button  -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="24"
                FontWeight="SemiBold"
                Text="Notification History" />
            <Button
                Margin="16,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Command="{Binding ClearHistoryCommand}"
                Content="Clear"
                Padding="12,4" />
        </DockPanel>

        <!--  Notification list  -->
        <ListView
            Grid.Row="1"
            ItemsSource="{Binding Entries}"
            VirtualizingPanel.IsVirtualizing="True">
            <ListView.View>
                <GridView>
                    <GridViewColumn
                        Width="100"
                        DisplayMemberBinding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                        Header="Time" />
                    <GridViewColumn
                        Width="200"
                        DisplayMemberBinding="{Binding Title}"
                        Header="Title" />
                    <GridViewColumn
                        Width="400"
                        DisplayMemberBinding="{Binding Message}"
                        Header="Message" />
                    <GridViewColumn
                        Width="150"
                        DisplayMemberBinding="{Binding EventType}"
                        Header="Type" />
                </GridView>
            </ListView.View>
        </ListView>

        <!--  Empty state  -->
        <TextBlock
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="16"
            Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground2}"
            Text="No notifications yet.">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Entries.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>