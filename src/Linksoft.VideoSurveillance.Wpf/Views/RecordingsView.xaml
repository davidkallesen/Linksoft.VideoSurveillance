<UserControl
    x:Class="Linksoft.VideoSurveillance.Wpf.Views.RecordingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:Linksoft.VideoSurveillance.Wpf.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:RecordingsViewModel}"
    Loaded="OnLoaded"
    mc:Ignorable="d">

    <Grid Margin="16">
        <atc:GridEx Rows="Auto,*,Auto">

            <!--  Filter Row  -->
            <atc:GridEx
                Grid.Row="0"
                Margin="0,0,0,16"
                Columns="Auto,180,Auto,140,Auto,140,*,Auto">
                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Text="Camera" />
                <ComboBox
                    Grid.Column="1"
                    DisplayMemberPath="Value"
                    ItemsSource="{Binding Path=CameraFilters}"
                    SelectedValue="{Binding Path=SelectedCameraFilter}"
                    SelectedValuePath="Key" />
                <TextBlock
                    Grid.Column="2"
                    Margin="16,0,8,0"
                    VerticalAlignment="Center"
                    Text="Day" />
                <ComboBox
                    Grid.Column="3"
                    DisplayMemberPath="Value"
                    ItemsSource="{Binding Path=DayFilterItems}"
                    SelectedValue="{Binding Path=SelectedDayFilter}"
                    SelectedValuePath="Key" />
                <TextBlock
                    Grid.Column="4"
                    Margin="16,0,8,0"
                    VerticalAlignment="Center"
                    Text="Time" />
                <ComboBox
                    Grid.Column="5"
                    DisplayMemberPath="Value"
                    ItemsSource="{Binding Path=TimeFilterItems}"
                    SelectedValue="{Binding Path=SelectedTimeFilter}"
                    SelectedValuePath="Key" />
                <Button
                    Grid.Column="7"
                    Padding="16,6"
                    Command="{Binding Path=RefreshCommand}"
                    Content="Refresh" />
            </atc:GridEx>

            <!--  Recordings DataGrid  -->
            <DataGrid
                Grid.Row="1"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                IsReadOnly="True"
                ItemsSource="{Binding Path=FilteredRecordings}"
                SelectedItem="{Binding Path=SelectedRecording}"
                SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding Path=CameraName}"
                        Header="Camera" />
                    <DataGridTextColumn
                        Width="160"
                        Binding="{Binding Path=FormattedRecordingTime}"
                        Header="Date/Time" />
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding Path=FormattedDuration}"
                        Header="Duration" />
                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding Path=FormattedFileSize}"
                        Header="Size" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Path=FileName}"
                        Header="File Name" />
                </DataGrid.Columns>
                <DataGrid.InputBindings>
                    <MouseBinding Command="{Binding Path=PlayCommand}" MouseAction="LeftDoubleClick" />
                </DataGrid.InputBindings>
            </DataGrid>

            <!--  Status Message  -->
            <TextBlock
                Grid.Row="2"
                Margin="0,8,0,0"
                Foreground="{DynamicResource AtcApps.Brushes.Gray5}"
                Text="{Binding Path=StatusMessage}" />

        </atc:GridEx>

        <!--  Loading overlay  -->
        <Border Background="#80000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                Foreground="White"
                Text="Loading recordings..." />
        </Border>
    </Grid>
</UserControl>