<atc:NiceWindow
    x:Class="Linksoft.VideoSurveillance.Wpf.Dialogs.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Linksoft.VideoSurveillance.Wpf.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:Linksoft.VideoSurveillance.Wpf.Core.Dialogs.Parts.Settings;assembly=Linksoft.VideoSurveillance.Wpf.Core"
    Title="Settings"
    Width="800"
    Height="600"
    MinWidth="600"
    MinHeight="500"
    d:DataContext="{d:DesignInstance Type=dialogs:SettingsDialogViewModel,
                                     IsDesignTimeCreatable=False}"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    WindowStyle="ToolWindow"
    mc:Ignorable="d">

    <atc:NiceWindow.Resources>
        <Style BasedOn="{StaticResource {x:Type GroupBox}}" TargetType="GroupBox">
            <Setter Property="Padding" Value="10,10,20,20" />
        </Style>
    </atc:NiceWindow.Resources>

    <atc:GridEx Margin="16" Rows="*,Auto">

        <!--  Tabbed Settings  -->
        <TabControl
            Grid.Row="0"
            BorderThickness="0"
            TabStripPlacement="Left">

            <!--  General Tab  -->
            <TabItem Width="180" Header="General">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                        <settings:GeneralAppearanceSettings />
                        <settings:GeneralStartupSettings />
                    </atc:UniformSpacingPanel>
                </ScrollViewer>
            </TabItem>

            <!--  Camera Display Tab  -->
            <TabItem Header="Camera Display">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                        <settings:CameraDisplayOverlaySettings />
                        <settings:CameraDisplayGridLayoutSettings />
                        <settings:CameraDisplaySnapshotSettings />
                    </atc:UniformSpacingPanel>
                </ScrollViewer>
            </TabItem>

            <!--  Connection Tab  -->
            <TabItem Header="Connection">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                        <settings:ConnectionDefaultCameraSettings />
                        <settings:ConnectionConnectionSettings />
                        <settings:ConnectionNotificationsSettings />
                    </atc:UniformSpacingPanel>
                </ScrollViewer>
            </TabItem>

            <!--  Performance Tab  -->
            <TabItem Header="Performance">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                        <settings:PerformanceVideoSettings />
                        <settings:PerformanceStreamingSettings />
                    </atc:UniformSpacingPanel>
                </ScrollViewer>
            </TabItem>

            <!--  Motion Detection Tab  -->
            <TabItem Header="Motion Detection">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                        <settings:MotionDetectionAnalysisSettings />
                        <settings:MotionDetectionBoundingBoxSettings />
                    </atc:UniformSpacingPanel>
                </ScrollViewer>
            </TabItem>

            <!--  Capture Tab  -->
            <TabItem Header="Capture">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                        <settings:CaptureRecordingSettings />
                    </atc:UniformSpacingPanel>
                </ScrollViewer>
            </TabItem>

            <!--  Timelapse Tab  -->
            <TabItem Header="Timelapse">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                        <settings:TimelapseSettings />
                    </atc:UniformSpacingPanel>
                </ScrollViewer>
            </TabItem>

            <!--  Storage Tab  -->
            <TabItem Header="Storage">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                        <settings:RecordingSegmentationSettings />
                        <settings:RecordingMediaCleanupSettings />
                        <settings:RecordingPlaybackOverlaySettings />
                    </atc:UniformSpacingPanel>
                </ScrollViewer>
            </TabItem>

            <!--  Advanced Tab  -->
            <TabItem Header="Advanced">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <atc:UniformSpacingPanel Orientation="Vertical" Spacing="20">
                        <settings:AdvancedLoggingSettings />
                        <settings:AdvancedMaintenanceSettings />
                    </atc:UniformSpacingPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!--  Dialog Buttons  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                MinWidth="80"
                Margin="0,0,8,0"
                Padding="16,8"
                Command="{Binding Path=SaveCommand}"
                Content="Save"
                IsDefault="True" />
            <Button
                MinWidth="80"
                Padding="16,8"
                Command="{Binding Path=CancelCommand}"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>
    </atc:GridEx>
</atc:NiceWindow>
