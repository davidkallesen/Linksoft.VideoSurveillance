<atc:NiceWindow
    x:Class="Linksoft.VideoSurveillance.Wpf.Dialogs.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="About Linksoft Video Surveillance"
    Width="420"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="ToolWindow"
    mc:Ignorable="d">

    <atc:GridEx Margin="24" Rows="Auto,Auto,Auto,Auto,Auto">

        <!--  Application Title  -->
        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Center"
            FontSize="20"
            FontWeight="Bold"
            Text="Linksoft Video Surveillance" />

        <!--  Version  -->
        <TextBlock
            Grid.Row="1"
            Margin="0,16,0,0"
            FontSize="14">
            <Run Text="Version: " />
            <Run x:Name="VersionRun" />
        </TextBlock>

        <!--  Description  -->
        <TextBlock
            Grid.Row="2"
            Margin="0,16,0,0"
            FontSize="13"
            Text="WPF desktop client for the Linksoft VideoSurveillance API server. Provides live camera viewing, recording management, and system configuration through a native Windows interface."
            TextWrapping="Wrap" />

        <!--  Copyright  -->
        <TextBlock
            Grid.Row="3"
            Margin="0,16,0,0"
            FontSize="12">
            <Run Text="Copyright" />
            <Run Text=" " />
            <Run x:Name="YearRun" />
            <Run Text=" Linksoft. All rights reserved." />
        </TextBlock>

        <!--  OK Button  -->
        <Button
            Grid.Row="4"
            MinWidth="80"
            Margin="0,24,0,0"
            Padding="16,8"
            HorizontalAlignment="Center"
            Click="OnOkClick"
            Content="OK"
            IsDefault="True" />
    </atc:GridEx>
</atc:NiceWindow>
