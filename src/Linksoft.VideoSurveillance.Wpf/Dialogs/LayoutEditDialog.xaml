<atc:NiceWindow
    x:Class="Linksoft.VideoSurveillance.Wpf.Dialogs.LayoutEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Linksoft.VideoSurveillance.Wpf.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding DialogTitle}"
    Width="400"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    d:DataContext="{d:DesignInstance Type=dialogs:LayoutEditDialogViewModel}"
    mc:Ignorable="d">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Layout Settings  -->
        <GroupBox Grid.Row="0" Header="Layout">
            <StackPanel Margin="8">
                <atc:LabelTextBox
                    Margin="0,4"
                    IsMandatory="True"
                    LabelText="Layout Name"
                    Text="{Binding LayoutName, UpdateSourceTrigger=PropertyChanged}" />
                <atc:LabelIntegerBox
                    Margin="0,4"
                    LabelText="Rows"
                    Maximum="10"
                    Minimum="1"
                    Value="{Binding Rows, UpdateSourceTrigger=PropertyChanged}" />
                <atc:LabelIntegerBox
                    Margin="0,4"
                    LabelText="Columns"
                    Maximum="10"
                    Minimum="1"
                    Value="{Binding Columns, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </GroupBox>

        <!--  Buttons  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                MinWidth="80"
                Margin="0,0,8,0"
                Command="{Binding SaveCommand}"
                Content="Save"
                IsDefault="True" />
            <Button
                MinWidth="80"
                Command="{Binding CancelCommand}"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</atc:NiceWindow>