<atc:NiceWindow
    x:Class="Linksoft.VideoSurveillance.Wpf.Dialogs.CameraEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Linksoft.VideoSurveillance.Wpf.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding DialogTitle}"
    Width="500"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    d:DataContext="{d:DesignInstance Type=dialogs:CameraEditDialogViewModel}"
    mc:Ignorable="d">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Connection Settings  -->
        <GroupBox Grid.Row="0" Header="Connection">
            <StackPanel Margin="8">
                <atc:LabelTextBox
                    Margin="0,4"
                    IsMandatory="True"
                    LabelText="Display Name"
                    Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                <atc:LabelTextBox
                    Margin="0,4"
                    LabelText="Description"
                    Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                <atc:LabelTextBox
                    Margin="0,4"
                    IsMandatory="True"
                    LabelText="IP Address"
                    Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" />
                <atc:LabelIntegerBox
                    Margin="0,4"
                    LabelText="Port"
                    Value="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                <atc:LabelComboBox
                    Margin="0,4"
                    Items="{Binding ProtocolItems}"
                    LabelText="Protocol"
                    SelectedKey="{Binding SelectedProtocol}" />
                <atc:LabelTextBox
                    Margin="0,4"
                    LabelText="Path"
                    Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </GroupBox>

        <!--  Authentication  -->
        <GroupBox
            Grid.Row="1"
            Margin="0,8,0,0"
            Header="Authentication">
            <StackPanel Margin="8">
                <atc:LabelTextBox
                    Margin="0,4"
                    LabelText="Username"
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                <atc:LabelPasswordBox
                    Margin="0,4"
                    LabelText="Password"
                    Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </GroupBox>

        <!--  Stream Settings  -->
        <GroupBox
            Grid.Row="2"
            Margin="0,8,0,0"
            Header="Stream Settings">
            <StackPanel Margin="8">
                <atc:LabelComboBox
                    Margin="0,4"
                    Items="{Binding OverlayPositionItems}"
                    LabelText="Overlay Position"
                    SelectedKey="{Binding SelectedOverlayPosition}" />
                <atc:LabelComboBox
                    Margin="0,4"
                    Items="{Binding RtspTransportItems}"
                    LabelText="RTSP Transport"
                    SelectedKey="{Binding SelectedRtspTransport}" />
                <CheckBox
                    Margin="0,4"
                    Content="Use Low Latency Mode"
                    IsChecked="{Binding StreamUseLowLatencyMode}" />
                <atc:LabelIntegerBox
                    Margin="0,4"
                    LabelText="Max Latency (ms)"
                    Value="{Binding StreamMaxLatencyMs, UpdateSourceTrigger=PropertyChanged}" />
                <atc:LabelIntegerBox
                    Margin="0,4"
                    LabelText="Buffer Duration (ms)"
                    Value="{Binding StreamBufferDurationMs, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </GroupBox>

        <!--  Buttons  -->
        <StackPanel
            Grid.Row="3"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                MinWidth="80"
                Margin="0,0,8,0"
                Command="{Binding SaveCommand}"
                Content="Save"
                IsDefault="True" />
            <Button
                MinWidth="80"
                Command="{Binding CancelCommand}"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</atc:NiceWindow>