<UserControl
    x:Class="Linksoft.VideoSurveillance.Wpf.UserControls.CameraTileControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lve="clr-namespace:Linksoft.VideoPlayer.Wpf;assembly=Linksoft.VideoPlayer.Wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:coreControls="clr-namespace:Linksoft.VideoSurveillance.Wpf.Core.UserControls;assembly=Linksoft.VideoSurveillance.Wpf.Core"
    xmlns:viewModels="clr-namespace:Linksoft.VideoSurveillance.Wpf.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:CameraTileViewModel}"
    mc:Ignorable="d">

    <!--  ReSharper disable Xaml.BindingWithContextNotResolved  -->
    <Grid Background="Black">
        <!--  Video Player with visual overlay inside (required due to DirectX airspace)  -->
        <lve:VideoHost Player="{Binding Player}">
            <!--  Visual overlay content - renders on top of video  -->
            <Grid Background="Transparent">
                <!--  Camera Info Overlay (Top-Left)  -->
                <Border
                    Margin="8"
                    Padding="6,4"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#99000000"
                    CornerRadius="3">
                    <StackPanel>
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding Path=HostDataContext.DisplayName}" />
                        <!--  Connection status dot + text  -->
                        <StackPanel Orientation="Horizontal">
                            <Ellipse
                                Width="6"
                                Height="6"
                                VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=HostDataContext.ConnectionState}" Value="connected">
                                                <Setter Property="Fill" Value="LimeGreen" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Path=HostDataContext.ConnectionState}" Value="connecting">
                                                <Setter Property="Fill" Value="Orange" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Path=HostDataContext.ConnectionState}" Value="error">
                                                <Setter Property="Fill" Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock
                                Margin="4,0,0,0"
                                FontSize="9"
                                Foreground="#AAAAAA"
                                Text="{Binding Path=HostDataContext.ConnectionState}" />
                        </StackPanel>
                        <!--  Recording indicator (red dot, visible when IsRecording)  -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=HostDataContext.IsRecording}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Ellipse
                                Width="6"
                                Height="6"
                                VerticalAlignment="Center"
                                Fill="Red" />
                            <TextBlock
                                Margin="4,0,0,0"
                                FontSize="9"
                                Foreground="Red"
                                Text="REC" />
                        </StackPanel>
                        <!--  Motion indicator (orange dot, visible when IsMotionDetected)  -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=HostDataContext.IsMotionDetected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Ellipse
                                Width="6"
                                Height="6"
                                VerticalAlignment="Center"
                                Fill="Orange" />
                            <TextBlock
                                Margin="4,0,0,0"
                                FontSize="9"
                                Foreground="Orange"
                                Text="MOTION" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Motion bounding box overlay  -->
                <coreControls:MotionBoundingBoxOverlay
                    AnalysisHeight="{Binding Path=HostDataContext.AnalysisHeight}"
                    AnalysisWidth="{Binding Path=HostDataContext.AnalysisWidth}"
                    IsHitTestVisible="False" />
            </Grid>
        </lve:VideoHost>

        <!--  "No stream" placeholder when not streaming  -->
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="14"
            Foreground="#666666"
            Text="No Stream">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStreaming}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
    <!--  ReSharper restore Xaml.BindingWithContextNotResolved  -->
</UserControl>