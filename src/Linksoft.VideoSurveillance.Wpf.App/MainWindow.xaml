<atcTheming:NiceWindow
    x:Class="Linksoft.VideoSurveillance.Wpf.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="clr-namespace:Linksoft.VideoSurveillance.Wpf.App"
    xmlns:atcTheming="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fluent="urn:fluent-ribbon"
    xmlns:fontIcons="clr-namespace:Atc.Wpf.FontIcons;assembly=Atc.Wpf.FontIcons"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title=".:: Linksoft Video Surveillance ::."
    Width="1500"
    Height="1000"
    MinWidth="700"
    MinHeight="400"
    d:DataContext="{d:DesignInstance Type=app:MainWindowViewModel}"
    mc:Ignorable="d">

    <atcTheming:NiceWindow.InputBindings>
        <KeyBinding
            Key="D1"
            Command="{Binding Path=ViewLiveViewCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="D2"
            Command="{Binding Path=ViewDashboardCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="D3"
            Command="{Binding Path=ViewCamerasCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="D4"
            Command="{Binding Path=ViewLayoutsCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="D5"
            Command="{Binding Path=ViewRecordingsCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="D6"
            Command="{Binding Path=ViewNotificationsCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="N"
            Command="{Binding Path=ViewCamerasCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="OemComma"
            Command="{Binding Path=ShowSettingsCommand}"
            Modifiers="Ctrl" />
        <KeyBinding Key="F5" Command="{Binding Path=RefreshCurrentViewCommand}" />
        <KeyBinding Key="F11" Command="{Binding Path=ToggleFullScreenCommand}" />
        <KeyBinding Key="F1" Command="{Binding Path=ShowKeyboardShortcutsCommand}" />
    </atcTheming:NiceWindow.InputBindings>

    <AdornerDecorator>
    <atcTheming:GridEx Rows="Auto,*,Auto">

        <!--  Ribbon  -->
        <fluent:Ribbon
            Grid.Row="0"
            AutomaticStateManagement="False"
            CanCustomizeQuickAccessToolBar="True"
            IsQuickAccessToolBarMenuDropDownVisible="True"
            IsQuickAccessToolBarVisible="True">

            <!--  Quick Access Toolbar  -->
            <fluent:Ribbon.QuickAccessItems>
                <fluent:QuickAccessMenuItem IsChecked="True">
                    <fluent:Button
                        Command="{Binding Path=ViewLiveViewCommand}"
                        Header="Live View"
                        Size="Small">
                        <fluent:Button.Icon>
                            <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Video" />
                        </fluent:Button.Icon>
                    </fluent:Button>
                </fluent:QuickAccessMenuItem>
                <fluent:QuickAccessMenuItem IsChecked="True">
                    <fluent:Button
                        Command="{Binding Path=RefreshCurrentViewCommand}"
                        Header="Refresh"
                        Size="Small">
                        <fluent:Button.Icon>
                            <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="SyncAlt" />
                        </fluent:Button.Icon>
                    </fluent:Button>
                </fluent:QuickAccessMenuItem>
                <fluent:QuickAccessMenuItem IsChecked="True">
                    <fluent:Button
                        Command="{Binding Path=ShowSettingsCommand}"
                        Header="Settings"
                        Size="Small">
                        <fluent:Button.Icon>
                            <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Cog" />
                        </fluent:Button.Icon>
                    </fluent:Button>
                </fluent:QuickAccessMenuItem>
            </fluent:Ribbon.QuickAccessItems>

            <!--  Backstage  -->
            <fluent:Ribbon.Menu>
                <fluent:Backstage x:Name="Backstage" IsOpenChanged="OnBackstageIsOpenChanged">
                    <fluent:BackstageTabControl>
                        <fluent:Button
                            Command="{Binding Path=ChangeServerCommand}"
                            Header="Change Server"
                            KeyTip="V"
                            Visibility="{Binding Path=ShowChangeServer}">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Server" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                        <fluent:Button
                            Command="{Binding Path=ShowSettingsCommand}"
                            Header="Settings"
                            KeyTip="S">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Cog" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                        <fluent:SeparatorTabItem />
                        <fluent:Button
                            Command="{Binding Path=ShowCheckForUpdatesCommand}"
                            Header="Check for Updates"
                            KeyTip="U">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Download" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                        <fluent:Button
                            Command="{Binding Path=ShowAboutCommand}"
                            Header="About"
                            KeyTip="A">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="InfoCircle" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                        <fluent:SeparatorTabItem />
                        <fluent:Button
                            Command="{Binding Path=ExitCommand}"
                            Header="Exit"
                            KeyTip="X">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="SignOutAlt" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                    </fluent:BackstageTabControl>
                </fluent:Backstage>
            </fluent:Ribbon.Menu>

            <!--  Home Tab  -->
            <fluent:RibbonTabItem Header="Home">
                <fluent:RibbonGroupBox Header="Live View">
                    <fluent:Button
                        Command="{Binding Path=ViewLiveViewCommand}"
                        Header="Live View"
                        Size="Large">
                        <fluent:Button.LargeIcon>
                            <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Video" />
                        </fluent:Button.LargeIcon>
                    </fluent:Button>
                </fluent:RibbonGroupBox>

                <fluent:RibbonGroupBox Header="Dashboard">
                    <fluent:Button
                        Command="{Binding Path=ViewDashboardCommand}"
                        Header="Dashboard"
                        Size="Large">
                        <fluent:Button.LargeIcon>
                            <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="TachometerAlt" />
                        </fluent:Button.LargeIcon>
                    </fluent:Button>
                </fluent:RibbonGroupBox>

                <fluent:RibbonGroupBox Header="Cameras">
                    <fluent:Button
                        Command="{Binding Path=ViewCamerasCommand}"
                        Header="Cameras"
                        Size="Large">
                        <fluent:Button.LargeIcon>
                            <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Camera" />
                        </fluent:Button.LargeIcon>
                    </fluent:Button>
                </fluent:RibbonGroupBox>

                <fluent:RibbonGroupBox Header="Layouts">
                    <fluent:Button
                        Command="{Binding Path=ViewLayoutsCommand}"
                        Header="Layouts"
                        Size="Large">
                        <fluent:Button.LargeIcon>
                            <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="ThLarge" />
                        </fluent:Button.LargeIcon>
                    </fluent:Button>
                </fluent:RibbonGroupBox>

                <fluent:RibbonGroupBox Header="Recordings">
                    <fluent:Button
                        Command="{Binding Path=ViewRecordingsCommand}"
                        Header="Recordings"
                        Size="Large">
                        <fluent:Button.LargeIcon>
                            <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Film" />
                        </fluent:Button.LargeIcon>
                    </fluent:Button>
                </fluent:RibbonGroupBox>

                <fluent:RibbonGroupBox Header="Notifications">
                    <fluent:Button
                        Command="{Binding Path=ViewNotificationsCommand}"
                        Header="Notifications"
                        Size="Large">
                        <fluent:Button.LargeIcon>
                            <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Bell" />
                        </fluent:Button.LargeIcon>
                    </fluent:Button>
                </fluent:RibbonGroupBox>
            </fluent:RibbonTabItem>
        </fluent:Ribbon>

        <!--  Main Content  -->
        <ContentControl
            x:Name="MainContent"
            Grid.Row="1"
            Content="{Binding CurrentView}" />

        <!--  Status Bar  -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding Path=StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Server: " /><Run Text="{Binding Path=ServerUrl, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Hub: " /><Run Text="{Binding Path=HubConnectionState, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Cameras: " /><Run Text="{Binding Path=ConnectedCameras, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Recordings: " /><Run Text="{Binding Path=ActiveRecordings, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem
                HorizontalAlignment="Right"
                Margin="0,0,16,0">
                <TextBlock>
                    <Run Text="Latency: " /><Run Text="{Binding Path=ServerLatency, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </atcTheming:GridEx>
    </AdornerDecorator>

</atcTheming:NiceWindow>