<atcTheming:NiceWindow
    x:Class="Linksoft.VideoSurveillance.Wpf.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="clr-namespace:Linksoft.VideoSurveillance.Wpf.App"
    xmlns:atcTheming="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fluent="urn:fluent-ribbon"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title=".:: Linksoft Video Surveillance ::."
    Width="1500"
    Height="1000"
    MinWidth="700"
    MinHeight="400"
    d:DataContext="{d:DesignInstance Type=app:MainWindowViewModel}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Ribbon  -->
        <fluent:Ribbon Grid.Row="0">
            <fluent:RibbonTabItem Header="Home" />
        </fluent:Ribbon>

        <!--  Main Content  -->
        <Grid Grid.Row="1" />

        <!--  Status Bar  -->
        <fluent:StatusBar Grid.Row="2">
            <fluent:StatusBarItem Title="Status" Content="Ready" />
        </fluent:StatusBar>
    </Grid>

</atcTheming:NiceWindow>
