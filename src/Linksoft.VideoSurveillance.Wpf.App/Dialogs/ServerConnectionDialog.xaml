<atcTheming:NiceWindow
    x:Class="Linksoft.VideoSurveillance.Wpf.App.Dialogs.ServerConnectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:atcTheming="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Linksoft.VideoSurveillance.Wpf.App.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Connect to Server"
    Width="520"
    Height="480"
    ResizeMode="NoResize"
    ShowInTaskbar="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="ToolWindow"
    d:DataContext="{d:DesignInstance Type=dialogs:ServerConnectionDialogViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <atcTheming:NiceWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </atcTheming:NiceWindow.Resources>

    <atc:GridEx Margin="20" Rows="Auto,*,Auto,Auto,Auto,Auto">

        <!--  Title  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="16"
            FontWeight="SemiBold"
            Text="Server Profiles" />

        <!--  Profiles List  -->
        <Border
            Grid.Row="1"
            BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
            BorderThickness="1"
            CornerRadius="4">
            <ListBox
                ItemsSource="{Binding Path=Profiles}"
                SelectedItem="{Binding Path=SelectedProfile}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,2">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Path=Name}" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                Text="{Binding Path=Url}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!--  Profile Buttons  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,8,0,0"
            HorizontalAlignment="Left"
            Orientation="Horizontal">
            <Button
                MinWidth="80"
                Margin="0,0,8,0"
                Padding="12,6"
                Command="{Binding Path=AddProfileCommand}"
                Content="Add" />
            <Button
                MinWidth="80"
                Margin="0,0,8,0"
                Padding="12,6"
                Command="{Binding Path=EditProfileCommand}"
                Content="Edit" />
            <Button
                MinWidth="80"
                Padding="12,6"
                Command="{Binding Path=DeleteProfileCommand}"
                Content="Delete" />
        </StackPanel>

        <!--  Server URL  -->
        <atc:LabelTextBox
            Grid.Row="3"
            Margin="0,16,0,0"
            LabelText="Server URL"
            Text="{Binding Path=ServerUrl, UpdateSourceTrigger=PropertyChanged}"
            WatermarkText="https://server:5000" />

        <!--  Status + Test Connection  -->
        <atc:GridEx
            Grid.Row="4"
            Margin="0,12,0,0"
            Columns="*,Auto">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{Binding Path=ConnectionStatus}" />
            <Button
                Grid.Column="1"
                MinWidth="120"
                Padding="12,6"
                Command="{Binding Path=TestConnectionCommand}"
                Content="Test Connection" />
        </atc:GridEx>

        <!--  Action Buttons  -->
        <atc:GridEx
            Grid.Row="5"
            Margin="0,20,0,0"
            Columns="Auto,*,Auto,Auto">
            <Button
                Grid.Column="0"
                MinWidth="110"
                Padding="16,8"
                Command="{Binding Path=ExitAppCommand}"
                Content="Exit Application" />
            <Button
                Grid.Column="2"
                MinWidth="100"
                Margin="0,0,8,0"
                Padding="16,8"
                Command="{Binding Path=ConnectCommand}"
                Content="Connect"
                IsDefault="True" />
            <Button
                Grid.Column="3"
                MinWidth="80"
                Padding="16,8"
                Command="{Binding Path=CancelCommand}"
                Content="Cancel"
                IsCancel="True" />
        </atc:GridEx>

    </atc:GridEx>
</atcTheming:NiceWindow>
