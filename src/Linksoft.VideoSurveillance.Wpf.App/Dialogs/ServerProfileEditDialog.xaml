<atcTheming:NiceWindow
    x:Class="Linksoft.VideoSurveillance.Wpf.App.Dialogs.ServerProfileEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:atcTheming="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Linksoft.VideoSurveillance.Wpf.App.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Server Profile"
    Width="420"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="ToolWindow"
    d:DataContext="{d:DesignInstance Type=dialogs:ServerProfileEditDialogViewModel, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <atc:GridEx Margin="20" Rows="Auto,Auto,Auto,Auto">

        <!--  Name  -->
        <atc:LabelTextBox
            Grid.Row="0"
            Margin="0,0,0,12"
            LabelText="Name"
            Text="{Binding Path=ProfileName, UpdateSourceTrigger=PropertyChanged}" />

        <!--  URL  -->
        <atc:LabelTextBox
            Grid.Row="1"
            Margin="0,0,0,12"
            LabelText="Server URL"
            Text="{Binding Path=Url, UpdateSourceTrigger=PropertyChanged}"
            WatermarkText="https://server:5000" />

        <!--  Description  -->
        <atc:LabelTextBox
            Grid.Row="2"
            Margin="0,0,0,20"
            LabelText="Description"
            Text="{Binding Path=Description, UpdateSourceTrigger=PropertyChanged}"
            WatermarkText="Optional description" />

        <!--  Buttons  -->
        <StackPanel
            Grid.Row="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                MinWidth="80"
                Margin="0,0,8,0"
                Padding="16,8"
                Command="{Binding Path=SaveCommand}"
                Content="Save"
                IsDefault="True" />
            <Button
                MinWidth="80"
                Padding="16,8"
                Command="{Binding Path=CancelCommand}"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>

    </atc:GridEx>
</atcTheming:NiceWindow>