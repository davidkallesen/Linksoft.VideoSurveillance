<UserControl
    x:Class="Linksoft.VideoSurveillance.Wpf.Core.Dialogs.Parts.CameraConfigurations.SourceTypePart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atcTranslation="https://github.com/atc-net/atc-wpf/tree/main/schemas/translations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Linksoft.VideoSurveillance.Wpf.Core.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=dialogs:CameraConfigurationDialogViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignWidth="700"
    mc:Ignorable="d">

    <StackPanel
        Margin="0,0,0,15"
        Orientation="Horizontal">

        <TextBlock
            Margin="0,0,15,0"
            VerticalAlignment="Center"
            FontWeight="SemiBold"
            Text="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                       Key=Source}" />

        <RadioButton
            Margin="0,0,20,0"
            VerticalAlignment="Center"
            Content="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                          Key=SourceTypeNetwork}"
            GroupName="CameraSource"
            IsChecked="{Binding Path=IsNetworkSource, Mode=TwoWay}"
            IsEnabled="{Binding Path=CanEditSource}" />

        <RadioButton
            VerticalAlignment="Center"
            Content="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                          Key=SourceTypeUsb}"
            GroupName="CameraSource"
            IsChecked="{Binding Path=IsUsbSource, Mode=TwoWay}"
            IsEnabled="{Binding Path=CanEditSource}" />

    </StackPanel>
</UserControl>