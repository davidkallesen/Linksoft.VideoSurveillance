<UserControl
    x:Class="Linksoft.VideoSurveillance.Wpf.Core.Dialogs.Parts.CameraConfigurations.UsbDevicePart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:atc="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:atcTranslation="https://github.com/atc-net/atc-wpf/tree/main/schemas/translations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Linksoft.VideoSurveillance.Wpf.Core.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=dialogs:CameraConfigurationDialogViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignWidth="700"
    mc:Ignorable="d">

    <atc:GridEx
        Columns="*,Auto"
        Rows="Auto,Auto,Auto,Auto,Auto,Auto">

        <!--  Device dropdown + Refresh button. Uses a vanilla
              ComboBox because atc:LabelComboBox is dictionary-keyed
              and our items are UsbDeviceDescriptor instances.  -->
        <StackPanel
            Grid.Row="0"
            Grid.Column="0">

            <TextBlock
                Margin="0,0,0,4"
                Text="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                           Key=SelectUsbDevice}" />

            <ComboBox
                DisplayMemberPath="FriendlyName"
                ItemsSource="{Binding Path=UsbDevices}"
                SelectedItem="{Binding Path=SelectedUsbDevice, Mode=TwoWay}" />
        </StackPanel>

        <Button
            Grid.Row="0"
            Grid.Column="1"
            Margin="8,18,0,0"
            VerticalAlignment="Center"
            Padding="12,6"
            Command="{Binding Path=RefreshUsbDevicesCommand}"
            Content="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                          Key=Refresh}" />

        <!--  Capability-driven dropdowns. Items cascade off the
              selected device's advertised stream formats: resolution
              first, then frame rate, then pixel format.  -->
        <StackPanel
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,8,0,0">

            <TextBlock
                Margin="0,0,0,4"
                Text="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                           Key=UsbResolution}" />

            <ComboBox
                ItemsSource="{Binding Path=UsbResolutionItems}"
                SelectedItem="{Binding Path=SelectedUsbResolution, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,8,0,0">

            <TextBlock
                Margin="0,0,0,4"
                Text="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                           Key=UsbFrameRate}" />

            <ComboBox
                ItemsSource="{Binding Path=UsbFrameRateItems}"
                SelectedItem="{Binding Path=UsbFrameRate, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel
            Grid.Row="3"
            Grid.Column="0"
            Margin="0,8,0,0">

            <TextBlock
                Margin="0,0,0,4"
                Text="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                           Key=UsbPixelFormat}" />

            <ComboBox
                IsEditable="True"
                ItemsSource="{Binding Path=UsbPixelFormatItems}"
                Text="{Binding Path=UsbPixelFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <CheckBox
            Grid.Row="4"
            Grid.Column="0"
            Margin="0,8,0,0"
            Content="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                          Key=UsbCaptureAudio}"
            IsChecked="{Binding Path=UsbCaptureAudio, Mode=TwoWay}" />

        <!--  Audio device name. Greyed out unless the Capture audio
              checkbox above is ticked — the model preserves a typed-in
              name across toggles, but typing while audio is off is
              rarely intentional.  -->
        <atc:LabelTextBox
            Grid.Row="5"
            Grid.Column="0"
            Margin="0,8,0,0"
            IsEnabled="{Binding Path=UsbCaptureAudio}"
            LabelText="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                            Key=UsbAudioDeviceName}"
            Text="{Binding Path=UsbAudioDeviceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

    </atc:GridEx>
</UserControl>