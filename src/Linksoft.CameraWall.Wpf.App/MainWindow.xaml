<atcTheming:NiceWindow
    x:Class="Linksoft.CameraWall.Wpf.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="clr-namespace:Linksoft.CameraWall.Wpf.App"
    xmlns:atcTheming="https://github.com/atc-net/atc-wpf/tree/main/schemas"
    xmlns:atcTranslation="https://github.com/atc-net/atc-wpf/tree/main/schemas/translations"
    xmlns:cw="clr-namespace:Linksoft.VideoSurveillance.Wpf.Core.UserControls;assembly=Linksoft.VideoSurveillance.Wpf.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fluent="urn:fluent-ribbon"
    xmlns:fontIcons="clr-namespace:Atc.Wpf.FontIcons;assembly=Atc.Wpf.FontIcons"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title=".:: Linksoft Camera Wall ::."
    Width="1500"
    Height="1000"
    MinWidth="700"
    MinHeight="400"
    d:DataContext="{d:DesignInstance Type=app:MainWindowViewModel}"
    Icon="pack://application:,,,/Linksoft.VideoSurveillance.Wpf.Core;component/Resources/Images/cctv-camera.ico"
    WindowStartupLocation="CenterScreen"
    WindowState="{Binding Path=WindowState}"
    mc:Ignorable="d">

    <atcTheming:NiceWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </atcTheming:NiceWindow.Resources>

    <AdornerDecorator>
        <atcTheming:GridEx Rows="Auto,*,Auto">

            <!--  Ribbon  -->
            <fluent:Ribbon
                Grid.Row="0"
                AutomaticStateManagement="False"
                CanCustomizeQuickAccessToolBar="False"
                IsMinimized="{Binding Path=IsRibbonMinimized, Mode=TwoWay}"
                IsQuickAccessToolBarMenuDropDownVisible="False"
                IsQuickAccessToolBarVisible="False">
                <!--  Backstage  -->
                <fluent:Ribbon.Menu>
                    <fluent:Backstage x:Name="Backstage" IsOpenChanged="OnBackstageIsOpenChanged">
                        <fluent:BackstageTabControl>
                            <fluent:Button
                                Command="{Binding Path=ShowSettingsCommand}"
                                Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                             Key=Settings}"
                                KeyTip="S">
                                <fluent:Button.Icon>
                                    <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Cog" />
                                </fluent:Button.Icon>
                            </fluent:Button>
                            <fluent:SeparatorTabItem />
                            <fluent:Button
                                Command="{Binding Path=ShowAboutCommand}"
                                Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                             Key=About}"
                                KeyTip="A">
                                <fluent:Button.Icon>
                                    <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="InfoCircle" />
                                </fluent:Button.Icon>
                            </fluent:Button>
                            <fluent:Button
                                Command="{Binding Path=CheckForUpdatesCommand}"
                                Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                             Key=CheckForUpdates}"
                                KeyTip="C">
                                <fluent:Button.Icon>
                                    <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="CloudDownloadAlt" />
                                </fluent:Button.Icon>
                            </fluent:Button>
                            <fluent:SeparatorTabItem />
                            <fluent:Button
                                Command="{Binding Path=ExitCommand}"
                                Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                             Key=Exit}"
                                KeyTip="X">
                                <fluent:Button.Icon>
                                    <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="SignOutAlt" />
                                </fluent:Button.Icon>
                            </fluent:Button>
                        </fluent:BackstageTabControl>
                    </fluent:Backstage>
                </fluent:Ribbon.Menu>

                <!--  Layouts Tab  -->
                <fluent:RibbonTabItem Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=Layouts}">
                    <fluent:RibbonGroupBox Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=CurrentLayoutGroup}">
                        <atcTheming:LabelComboBox
                            Width="250"
                            Margin="5,25,5,25"
                            HideAreas="All"
                            Items="{Binding Path=LayoutItems}"
                            LabelText="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                            Key=Layout}"
                            LabelWidthNumber="50"
                            SelectedKey="{Binding Path=SelectedLayoutId}" />
                    </fluent:RibbonGroupBox>

                    <fluent:RibbonGroupBox Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=Actions}">
                        <fluent:Button
                            Command="{Binding Path=NewLayoutCommand}"
                            Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                         Key=NewLayout}"
                            Size="Middle">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="PlusCircle" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                        <fluent:Button
                            Command="{Binding Path=RenameLayoutCommand}"
                            Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                         Key=RenameLayout}"
                            Size="Middle">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Edit" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                        <fluent:Button
                            Command="{Binding Path=AssignCameraCommand}"
                            Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                         Key=AssignCamera}"
                            Size="Middle">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Link" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                        <fluent:Button
                            Command="{Binding Path=DeleteLayoutCommand}"
                            Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                         Key=DeleteLayout}"
                            Size="Middle">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="TrashAlt" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                        <fluent:Button
                            Command="{Binding Path=SetAsStartupCommand}"
                            Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                         Key=SetAsStartup}"
                            Size="Middle">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Star" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                    </fluent:RibbonGroupBox>
                </fluent:RibbonTabItem>

                <!--  Cameras Tab  -->
                <fluent:RibbonTabItem Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=Cameras}">
                    <fluent:RibbonGroupBox Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=Camera}">
                        <fluent:Button
                            Command="{Binding Path=AddCameraCommand}"
                            Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                         Key=AddCamera}"
                            Size="Large">
                            <fluent:Button.LargeIcon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Camera" />
                            </fluent:Button.LargeIcon>
                        </fluent:Button>
                    </fluent:RibbonGroupBox>

                    <fluent:RibbonGroupBox Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=Actions}">
                        <fluent:Button
                            Command="{Binding Path=ReconnectAllCommand}"
                            Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                         Key=ReconnectAll}"
                            Size="Middle">
                            <fluent:Button.Icon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="SyncAlt" />
                            </fluent:Button.Icon>
                        </fluent:Button>
                    </fluent:RibbonGroupBox>
                </fluent:RibbonTabItem>

                <!--  View Tab  -->
                <fluent:RibbonTabItem Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=View}">
                    <fluent:RibbonGroupBox Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=Recordings}">
                        <fluent:Button
                            Command="{Binding Path=ShowRecordingsBrowserCommand}"
                            Header="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations,
                                                         Key=BrowseRecordings}"
                            Size="Large">
                            <fluent:Button.LargeIcon>
                                <fontIcons:ImageAwesomeSolid Foreground="{DynamicResource AtcApps.Brushes.ThemeForeground}" Icon="Film" />
                            </fluent:Button.LargeIcon>
                        </fluent:Button>
                    </fluent:RibbonGroupBox>
                </fluent:RibbonTabItem>
            </fluent:Ribbon>

            <!--  Camera Grid  -->
            <cw:CameraGrid
                x:Name="CameraGridControl"
                Grid.Row="1"
                CameraConfigurationChanged="CameraGrid_CameraConfigurationChanged"
                ConnectionStateChanged="CameraGrid_ConnectionStateChanged"
                DeleteCameraRequested="CameraGrid_DeleteCameraRequested"
                EditCameraRequested="CameraGrid_EditCameraRequested"
                FullScreenRequested="CameraGrid_FullScreenRequested"
                PositionChanged="CameraGrid_PositionChanged" />

            <!--  Status Bar  -->
            <StatusBar Grid.Row="2">
                <StatusBarItem>
                    <TextBlock Text="{Binding Path=StatusText}" />
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <TextBlock>
                        <Run Text="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=CamerasLabel}" />
                        <Run Text=" " /><Run Text="{Binding Path=CameraCount, Mode=OneWay}" />
                    </TextBlock>
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <TextBlock>
                        <Run Text="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=ConnectedLabel}" />
                        <Run Text=" " /><Run Text="{Binding Path=ConnectedCount, Mode=OneWay}" />
                    </TextBlock>
                </StatusBarItem>
                <StatusBarItem
                    HorizontalAlignment="Right"
                    Margin="0,0,16,0"
                    Visibility="{Binding Path=IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock>
                        <Hyperlink Command="{Binding Path=DownloadUpdateCommand}">
                            <Hyperlink.Style>
                                <Style TargetType="Hyperlink">
                                    <!--  Amber signals "attention" and stays readable on both dark and light statusbar backgrounds, regardless of accent color.  -->
                                    <Setter Property="Foreground" Value="#FFC107" />
                                    <Setter Property="TextDecorations" Value="Underline" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#FFE082" />
                                            <Setter Property="FontWeight" Value="Bold" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Hyperlink.Style>
                            <Run Text="{atcTranslation:Resx ResxName=Linksoft.VideoSurveillance.Wpf.Core.Resources.Translations, Key=UpdateAvailable}" />
                            <Run Text=": v" />
                            <Run Text="{Binding Path=UpdateVersion, Mode=OneWay}" />
                        </Hyperlink>
                    </TextBlock>
                </StatusBarItem>
            </StatusBar>
        </atcTheming:GridEx>
    </AdornerDecorator>
</atcTheming:NiceWindow>